    "./ok-pdf": "./dist/ok-pdf.js",
    "./ok-receipt": "./dist/ok-receipt.js",
    "./ok-invoice": "./dist/ok-invoice.js",
    "./ok-timeline": "./dist/ok-timeline.js",
    "./ok-qty-stepper": "./dist/ok-qty-stepper.js",
