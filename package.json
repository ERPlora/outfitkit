{
  "name": "@outfitkit/core",
  "version": "0.1.0",
  "description": "OutfitKit — librería de Web Components (Lit) que CONSTRUYE lo que Ionic no tiene (tree, data-table rica, inline-feedback, kpi/stat, stepper/wizard, calendar, kanban…) sobre primitivos de Ionic. Ionic es la base; OutfitKit cubre los huecos. npm + CDN, imports individuales, CSP-safe. Tema vía tokens --ok-* (fallback a --ion-*).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://erplora.github.io/outfitkit/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ERPlora/outfitkit.git"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/*.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": "./dist/define.js",
    "./store": {
      "types": "./dist/store/store.d.ts",
      "import": "./dist/store.js"
    },
    "./store-controller": {
      "types": "./dist/store/controller.d.ts",
      "import": "./dist/store-controller.js"
    },
    "./ok-store": "./dist/ok-store.js",
    "./ok-data-table": "./dist/ok-data-table.js",
    "./ok-mail": "./dist/ok-mail.js",
    "./ok-tree": "./dist/ok-tree.js",
    "./ok-inline-feedback": "./dist/ok-inline-feedback.js",
    "./ok-empty-state": "./dist/ok-empty-state.js",
    "./ok-kpi": "./dist/ok-kpi.js",
    "./ok-stat": "./dist/ok-stat.js",
    "./ok-stepper": "./dist/ok-stepper.js",
    "./ok-wizard": "./dist/ok-wizard.js",
    "./ok-contact-form": "./dist/ok-contact-form.js",
    "./ok-calendar": "./dist/ok-calendar.js",
    "./ok-kanban": "./dist/ok-kanban.js",
    "./ok-app-launcher": "./dist/ok-app-launcher.js",
    "./ok-split-button": "./dist/ok-split-button.js",
    "./ok-combo": "./dist/ok-combo.js",
    "./ok-tag-input": "./dist/ok-tag-input.js",
    "./ok-rating": "./dist/ok-rating.js",
    "./ok-otp": "./dist/ok-otp.js",
    "./ok-pinpad": "./dist/ok-pinpad.js",
    "./ok-currency": "./dist/ok-currency.js",
    "./ok-phone": "./dist/ok-phone.js",
    "./ok-dropzone": "./dist/ok-dropzone.js",
    "./ok-sparkline": "./dist/ok-sparkline.js",
    "./ok-chat": "./dist/ok-chat.js",
    "./ok-scheduler": "./dist/ok-scheduler.js",
    "./ok-menubar": "./dist/ok-menubar.js",
    "./ok-carousel": "./dist/ok-carousel.js",
    "./ok-signature": "./dist/ok-signature.js",
    "./ok-qr": "./dist/ok-qr.js",
    "./ok-audio": "./dist/ok-audio.js",
    "./ok-video": "./dist/ok-video.js",
    "./ok-pdf": "./dist/ok-pdf.js",
    "./ok-receipt": "./dist/ok-receipt.js",
    "./ok-invoice": "./dist/ok-invoice.js",
    "./ok-timeline": "./dist/ok-timeline.js",
    "./ok-qty-stepper": "./dist/ok-qty-stepper.js",
    "./ok-command-palette": "./dist/ok-command-palette.js",
    "./ok-color-picker": "./dist/ok-color-picker.js",
    "./ok-avatar": "./dist/ok-avatar.js",
    "./ok-status-pill": "./dist/ok-status-pill.js",
    "./ok-drawer": "./dist/ok-drawer.js",
    "./ok-page-header": "./dist/ok-page-header.js",
    "./ok-bento": "./dist/ok-bento.js",
    "./ok-bento-item": "./dist/ok-bento-item.js",
    "./ok-reveal": "./dist/ok-reveal.js",
    "./ok-feature-card": "./dist/ok-feature-card.js",
    "./ok-pricing-card": "./dist/ok-pricing-card.js",
    "./ok-product-card": "./dist/ok-product-card.js",
    "./ok-logo-cloud": "./dist/ok-logo-cloud.js",
    "./ok-testimonial": "./dist/ok-testimonial.js",
    "./ok-cta-band": "./dist/ok-cta-band.js",
    "./ok-language-select": "./dist/ok-language-select.js",
    "./ok-navbar": "./dist/ok-navbar.js",
    "./ok-footer": "./dist/ok-footer.js",
    "./ok-hero": "./dist/ok-hero.js",
    "./theme.css": "./dist/theme.example.css",
    "./layout.css": "./dist/layout.css",
    "./cdn": "./dist/outfitkit.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "verify:csp": "node scripts/assert-csp-safe.mjs dist"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
