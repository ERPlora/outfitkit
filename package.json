    "./tabbar.css": "./dist/tabbar.css",
    "./cdn": "./dist/outfitkit.js",
    "./bundle": "./dist/outfitkit.bundle.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.config.cdn.ts && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "generate:module-pages": "node scripts/generate-module-pages.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:csp": "node scripts/assert-csp-safe.mjs dist",
    "release": "npx --yes release-it"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@iconify-json/ion": "^1.2.7",
    "@types/node": "^24.10.1",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
